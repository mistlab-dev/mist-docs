# ─── MistDocs Docker 环境配置 ───
# 复制为 .env 后修改

# MySQL
MYSQL_ROOT_PASSWORD=root_pass_2026
MYSQL_DATABASE=mist_docs
MYSQL_USER=mist_docs
MYSQL_PASSWORD=mist_docs_pass

# 是否映射 MySQL 端口到宿主机（留空则不映射）
MYSQL_PORT_MAP=3306

# 应用
APP_PORT=8900

# JWT 密钥（生产环境务必修改）
JWT_SECRET=mist-docs-jwt-secret-change-me

# 日志级别: debug/info/warn/error
LOG_LEVEL=info
